def run_simulation():
    import pandas as pd
    import numpy as np
    import torch
    import torch.nn as nn
    import torch.optim as optim
    from sklearn.model_selection import train_test_split
    from sklearn.preprocessing import StandardScaler
    from sklearn.metrics import (
        accuracy_score, precision_score, recall_score,
        f1_score, roc_auc_score, confusion_matrix
    )

    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

    # ================================
    # BLOQUE 1 — Carga y preparación
    # ================================
    X_path = r"C:\Users\javie\Desktop\Archivos de la tesis\Sistema Inmune datos\Myeloides\matriz con genes de RF 966-193.csv"
    y_path = r"C:\Users\javie\Desktop\respuestas de los 45 pacientes TNBC - corregido.csv"

    X = pd.read_csv(X_path, index_col=0)
    y_df = pd.read_csv(y_path).set_index("patient_id").loc[X.index]
    y = y_df["respuesta"].values.astype(np.float32)

    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    # División aleatoria estratificada (70% entrenamiento, 30% prueba)
    random_state = np.random.randint(0, 10000)
    X_train, X_test, y_train, y_test = train_test_split(
        X_scaled, y, test_size=0.3, stratify=y, random_state=random_state)

    X_train_t = torch.tensor(X_train, dtype=torch.float32).to(device)
    y_train_t = torch.tensor(y_train.reshape(-1, 1), dtype=torch.float32).to(device)
    X_test_t = torch.tensor(X_test, dtype=torch.float32).to(device)
    y_test_t = torch.tensor(y_test.reshape(-1, 1), dtype=torch.float32).to(device)

    # ================================
    # BLOQUE 2 — Modelo y entrenamiento directo
    # ================================
    class MLPClassifier(nn.Module):
        def __init__(self, input_dim, hidden1, hidden2, dropout_rate):
            super(MLPClassifier, self).__init__()
            self.network = nn.Sequential(
                nn.Linear(input_dim, hidden1),
                nn.LeakyReLU(),
                nn.Dropout(dropout_rate),
                nn.Linear(hidden1, hidden2),
                nn.LeakyReLU(),
                nn.Dropout(dropout_rate),
                nn.Linear(hidden2, 1),
                nn.Sigmoid()
            )
        def forward(self, x):
            return self.network(x)

    # Hiperparámetros definidos previamente
    hidden1 = 36
    hidden2 = 40
    dropout_rate = 0.2619541892264762
    epochs = 100
    patience = 10

    model = MLPClassifier(
        input_dim=X_train.shape[1],
        hidden1=hidden1,
        hidden2=hidden2,
        dropout_rate=dropout_rate
    ).to(device)

    criterion = nn.BCELoss()
    optimizer = optim.AdamW(model.parameters(), lr=1e-3, weight_decay=1e-2)

    best_loss = float("inf")
    sin_mejora = 0

    for epoch in range(epochs):
        model.train()
        optimizer.zero_grad()
        outputs = model(X_train_t)
        loss = criterion(outputs, y_train_t)
        loss.backward()
        optimizer.step()

        model.eval()
        with torch.no_grad():
            val_loss = criterion(model(X_train_t), y_train_t)

        if val_loss.item() < best_loss:
            best_loss = val_loss.item()
            sin_mejora = 0
        else:
            sin_mejora += 1

        if sin_mejora >= patience:
            break

    # Evaluación en test
    model.eval()
    with torch.no_grad():
        y_pred_probs = model(X_test_t).cpu().numpy().flatten()
        y_pred = (y_pred_probs > 0.5).astype(int)

    acc = accuracy_score(y_test, y_pred)
    prec = precision_score(y_test, y_pred, zero_division=0, pos_label=1)
    rec = recall_score(y_test, y_pred, pos_label=1)
    f1 = f1_score(y_test, y_pred, pos_label=1)
    roc_auc = roc_auc_score(y_test, y_pred_probs)
    cm = confusion_matrix(y_test, y_pred, labels=[1, 0])

    return {
        "accuracy": acc,
        "precision": prec,
        "recall": rec,
        "f1": f1,
        "roc_auc": roc_auc,
        "conf_matrix": cm
    }

import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt
import os

# Número de simulaciones
num_simulaciones = 100

metricas = {
    "accuracy": [],
    "precision": [],
    "recall": [],
    "f1": [],
    "roc_auc": []
}
matrices = []

# Ejecutar simulaciones
for i in range(num_simulaciones):
    print(f"\n⚙️ Simulación {i+1}/{num_simulaciones}")
    resultados = run_simulation()
    
    for k in metricas:
        metricas[k].append(resultados[k])
    
    matrices.append(resultados["conf_matrix"])

# Promedio de métricas
print(f"\n📊 Promedio de métricas tras {num_simulaciones} simulaciones:")
for k in metricas:
    promedio = np.mean(metricas[k])
    print(f"{k.capitalize():<9}: {promedio:.4f}")

# Matriz de confusión promedio
confusion_prom = np.mean(matrices, axis=0)
confusion_prom_rounded = np.round(confusion_prom).astype(int)

print("\n📌 Matriz de confusión promedio (valores exactos):")
print(confusion_prom)

print("\n📌 Matriz de confusión promedio (redondeada):")
print(confusion_prom_rounded)

# Visualización
plt.figure(figsize=(6, 5))
sns.heatmap(confusion_prom_rounded, annot=True, fmt='d', cmap='Blues',
            annot_kws={"size": 16},
            xticklabels=["R", "NR"],
            yticklabels=["R", "NR"])
plt.title("Confusion Matrix - FFNN", fontsize=16)
plt.xlabel("Predicted", fontsize=14)
plt.ylabel("Actual", fontsize=14)
plt.xticks(fontsize=12)
plt.yticks(fontsize=12)
plt.tight_layout()

# Guardar en escritorio
desktop = os.path.join(os.path.expanduser("~"), "Desktop")
filename = os.path.join(desktop, "matriz_confusion2.jpg")
plt.savefig(filename, format='jpg', dpi=300)
plt.show()

print(f"\n✅ Imagen guardada como: {filename}")

