# ==========================
# BLOQUE 1: CARGA DE DATOS (45 PACIENTES TNBC)
# ==========================

import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import train_test_split

# 📌 Nuevas rutas
#ruta_X = r"C:\Users\javie\Desktop\Archivos de la tesis\Tcell datos\Matriz de expresiones en Tcell 45 pacientes.csv"
ruta_X = r"C:\Users\javie\Desktop\Archivos de la tesis\Sistema Inmune datos\Myeloides\Matriz de expresiones en Myeloid 45 pacientes.csv"
ruta_y = r"C:\Users\javie\Desktop\Archivos de la tesis\Listas de genes de los datasets\Todos los pacientes TNBC\Expresion genica TNBC\respuestas de los 45 pacientes TNBC.csv"

# 1. Cargar los datos
X_df = pd.read_csv(ruta_X)
y_df = pd.read_csv(ruta_y)

# 2. Extraer X e y
X = X_df.iloc[:, 1:].values  # ignoramos la columna 'paciente'
y = y_df['respuesta'].values.astype(int)  # ya deben estar como 0 y 1

# 3. Escalado opcional
aplicar_scaler = False

if aplicar_scaler:
    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)
else:
    X_scaled = X

# 4. División estratificada
X_temp, X_test, y_temp, y_test = train_test_split(
    X_scaled, y, test_size=0.3, stratify=y, random_state=199)

X_train, X_val, y_train, y_val = train_test_split(
    X_temp, y_temp, test_size=0.2, stratify=y_temp, random_state=42)

# 5. Confirmación
print("Tamaños de los conjuntos:")
print("Train:", X_train.shape)
print("Val:  ", X_val.shape)
print("Test: ", X_test.shape)
print("Distribución en y_test:", np.bincount(y_test))

###################################################################################################################
# ==========================
# BLOQUE 2: ENTRENAMIENTO DEL RANDOM FOREST
# ==========================

from sklearn.ensemble import RandomForestClassifier

# Inicializar el modelo
rf_model = RandomForestClassifier(
    n_estimators=193,
    class_weight='balanced',
    max_features=31,  # <--- Aquí defines cuántos genes evaluar por nodo
    random_state=25,
    n_jobs=-1  # Utiliza todos los núcleos disponibles
)

# Entrenar el modelo
rf_model.fit(X_train, y_train)

# Verificar entrenamiento
print("Modelo entrenado correctamente con", len(rf_model.estimators_), "árboles.")
###############################################################################################################
# ==========================
# BLOQUE 3: EVALUACIÓN DEL MODELO BINARIO (TNBC, TP ARRIBA IZQ.)
# ==========================

from sklearn.metrics import accuracy_score, classification_report, confusion_matrix
import matplotlib.pyplot as plt
import seaborn as sns

def evaluar_modelo_binario(modelo, X, y, conjunto_nombre):
    # Predicción
    y_pred = modelo.predict(X)

    # Métricas
    print(f"\n🔍 Resultados en el conjunto de {conjunto_nombre}:")
    print("Accuracy:", accuracy_score(y, y_pred))
    print("\nClassification Report:")
    print(classification_report(
        y, y_pred,
        target_names=["No Respondedor", "Respondedor"],
        zero_division=0
    ))

    # Matriz de confusión con clase positiva primero (1 = Respondedor)
    cm = confusion_matrix(y, y_pred, labels=[1, 0])

    # Visualización
    plt.figure(figsize=(5, 4))
    sns.heatmap(
        cm,
        annot=True,
        fmt='d',
        cmap='Blues',
        xticklabels=["Respondedor", "No Respondedor"],
        yticklabels=["Respondedor", "No Respondedor"]
    )
    plt.xlabel('Predicción')
    plt.ylabel('Real')
    plt.title(f'Matriz de Confusión - {conjunto_nombre}')
    plt.tight_layout()
    plt.show()

# Ejecutar en validación y test
evaluar_modelo_binario(rf_model, X_val, y_val, "Validación")
evaluar_modelo_binario(rf_model, X_test, y_test, "Test")

