import pandas as pd
import os
import matplotlib.pyplot as plt
import seaborn as sns

# Ruta al Escritorio (por si no estaba definida antes)
desktop = os.path.join(os.path.expanduser("~"), "Desktop")

# Obtener los nombres de los genes (ignoramos la columna 'paciente')
genes = X_df.columns[1:]

# Extraer las importancias del modelo entrenado
importancias = rf_model.feature_importances_

# Crear DataFrame con los genes y su importancia
df_importancia = pd.DataFrame({
    'Gen': genes,
    'Importancia': importancias
})

# Ordenar de mayor a menor importancia
df_importancia = df_importancia.sort_values(by='Importancia', ascending=False).reset_index(drop=True)

# Visualizar los top 20 genes más importantes
top_n = 20
plt.figure(figsize=(10, 6))
sns.barplot(x='Importancia', y='Gen', data=df_importancia.head(top_n), palette='crest')
plt.title(f'Top {top_n} genes más importantes (Random Forest - TNBC)')
plt.tight_layout()
# Guardar en el Escritorio
plt.savefig(os.path.join(desktop, "genprincRF.jpg"), format='jpg', dpi=300)
plt.show()

# (Opcional) Guardar el ranking completo
