# ==========================
# BLOQUE 5: CURVA ROC BINARIA - TNBC
# ==========================

from sklearn.metrics import roc_curve, auc

# Obtener las probabilidades del modelo para la clase positiva (respondedor = 1)
y_score = rf_model.predict_proba(X_test)[:, 1]

# Calcular FPR, TPR y AUC
fpr, tpr, thresholds = roc_curve(y_test, y_score)
roc_auc = auc(fpr, tpr)

# Visualizar la curva ROC
plt.figure(figsize=(8, 6))
plt.plot(fpr, tpr, color='darkorange', lw=2, label=f'AUC = {roc_auc:.2f}')
plt.plot([0, 1], [0, 1], color='gray', linestyle='--')  # línea aleatoria
plt.xlabel('Tasa de Falsos Positivos (FPR)')
plt.ylabel('Tasa de Verdaderos Positivos (TPR)')
plt.title('Curva ROC - Random Forest (TNBC)')
plt.legend(loc='lower right')
plt.grid(True)
plt.tight_layout()
plt.show()
